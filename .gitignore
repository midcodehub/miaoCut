# Python Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.venv-py39-backup

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Mac OS System Files
.DS_Store
.AppleDouble
.LSOverride

# IDEs / Editors
.idea/
.vscode/*
!.vscode/launch.json
*.swp
*.swo

# AI Models & Data 
# (因为我们在 launch.json 配置了将模型下载到项目目录下的 .u2net 文件夹，所以必须忽略，防止提交 170MB 的模型)
.u2net/

# User Data (feedback etc.)
data/
examples/raw/

# Logs
*.log

# Node / Tailwind
node_modules/
# 注意：output.css 必须提交（CF Pages 直接当静态文件 serve）
calib_images/
bench_out/
# models/ 下的所有 ONNX 模型都不进 git —— HF Space 上由 owner 手动维护（HF Web UI 或
# huggingface-cli upload）。GitHub workflow 推代码时不碰模型文件，避免 git-lfs / 100MB 上限。
models/*.onnx
models/*.bak

