# Cloudflare Pages 自定义响应头
# 文档：https://developers.cloudflare.com/pages/configuration/headers/

# 静态资源：长缓存
# output.css 和 app.js 没带 hash，所以不能用 immutable + 1 年缓存（更新后用户拿不到新版）。
# 折中：1 天 + must-revalidate，PSI "Use efficient cache lifetimes" 不再报错。
# 如果将来给文件名加上 hash（比如 output.<hash>.css），再换成 max-age=31536000, immutable。
/output.css
  Cache-Control: public, max-age=86400, must-revalidate
/app.js
  Cache-Control: public, max-age=86400, must-revalidate

# 图片：内容稳定，1 周缓存
/examples/*
  Cache-Control: public, max-age=604800, must-revalidate
/*.webp
  Cache-Control: public, max-age=604800, must-revalidate
/*.png
  Cache-Control: public, max-age=604800, must-revalidate

# robots.txt / sitemap：1 小时
/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
/sitemap.xml
  Cache-Control: public, max-age=3600
