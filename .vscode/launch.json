{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "U2NET_HOME": "${workspaceFolder}/.u2net"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Uvicorn running on http://.*:8000",
                "uriFormat": "http://127.0.0.1:8000"
            }
        }
    ]
}
