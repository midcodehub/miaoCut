{
  "name": "miaocut-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "MiaoCut 前端构建：用 Tailwind CLI 把 src/input.css 编译为根目录 output.css",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./output.css --watch",
    "og": "node scripts/og/generate.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "tailwindcss": "^3.4.17"
  }
}
